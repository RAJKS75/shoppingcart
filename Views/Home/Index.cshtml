@model IEnumerable<ShoppingCart.Models.Product>

@{
    ViewData["Title"] = "Shop";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5">Shop</h1>
            <p class="text-muted">Browse the latest products and add them to your cart.</p>
        </div>
        <a class="btn btn-outline-primary" asp-action="Cart">View Cart</a>
    </div>

    <div class="row gy-4">
        @foreach (var product in Model)
        {
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <img class="card-img-top" src="https://via.placeholder.com/450x250?text=@Uri.EscapeDataString(product.Name)" alt="@product.Name" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-muted">@product.Description</p>
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fw-bold h5 mb-0">$@product.Price</span>
                                <button class="btn btn-primary btn-sm" onclick="addToCart(@product.Id)">Add to cart</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        async function addToCart(productId) {
            const button = event.target;
            button.disabled = true;
            try {
                const response = await fetch('/api/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: productId, quantity: 1 })
                });
                if (response.ok) {
                    button.textContent = 'Added';
                    setTimeout(() => button.textContent = 'Add to cart', 1000);
                } else {
                    alert('Unable to add to cart.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Unable to add to cart.');
            } finally {
                button.disabled = false;
            }
        }
    </script>
}
